# ── 거래소 API (필수) ────────────────────────────────────────────────────────
# Bybit API 키 발급: https://www.bybit.com → 계정 → API 관리
# 권한: Contract Orders (읽기+쓰기), Positions (읽기)
# IP 제한 설정 권장 (서버 IP만 허용)
EXCHANGE_API_KEY=your_bybit_api_key_here
EXCHANGE_API_SECRET=your_bybit_api_secret_here

# ── Claude AI (선택, LLM 분석 기능) ─────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── OpenAI (선택, 멀티 LLM 앙상블) ─────────────────────────────────────────
# https://platform.openai.com → API keys
OPENAI_API_KEY=

# ── Telegram 알림 (선택, 강력 추천) ─────────────────────────────────────────
# 1. @BotFather 에서 /newbot 으로 봇 생성 → BOT_TOKEN 발급
# 2. 봇에 메시지 보낸 후 https://api.telegram.org/bot<TOKEN>/getUpdates 로 CHAT_ID 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
